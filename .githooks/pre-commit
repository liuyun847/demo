#!/bin/sh
# pre-commit hook: Godot 项目检查 → 运行测试 → 通过则允许提交
# 安装：git config core.hooksPath .githooks

PROJECT_DIR="$(git rev-parse --show-toplevel)"
GODOT="${GODOT_PATH:-C:/Users/MLTZ/Desktop/Godot_v4.6.1-stable_win64.exe}"
export GODOT
TEST_SCRIPT="res://addons/gut/gut_cmdln.gd"
TEST_OUTPUT="$PROJECT_DIR/save/test_output.xml"

cleanup() { rm -f "$PROJECT_DIR/.git/precommit-gut-output.tmp"; }
trap cleanup EXIT

cd "$PROJECT_DIR" || exit 1

# ── 步骤 1：Godot 项目错误检查（godot-debug）───────────
echo "=== [pre-commit] 1/2 Godot 项目错误检查（godot-debug）==="

powershell.exe -ExecutionPolicy Bypass -File "$PROJECT_DIR/.githooks/check_godot_project.ps1" "$PROJECT_DIR"
POWERSHELL_EXIT=$?

if [ $POWERSHELL_EXIT -ne 0 ]; then
    echo ""
    echo "=== [pre-commit] ❌ Godot 项目检查发现错误，提交已阻止 ==="
    echo "请先修复错误再重新提交。"
    exit 1
fi

echo "=== [pre-commit] ✅ Godot 项目检查通过 ==="

# ── 步骤 2：GUT 测试 ────────────────────────────────────
echo "=== [pre-commit] 2/2 运行 GUT 测试套件 ==="

GUT_OUTPUT="$PROJECT_DIR/.git/precommit-gut-output.tmp"

# 运行测试，保存原始输出和退出码
# -gcompact_mode 是 GUT 7.4.0+ 的选项；旧版本会忽略未知标志，无副作用
"$GODOT" --headless --path "$PROJECT_DIR" --script "$TEST_SCRIPT" -gcompact_mode > "$GUT_OUTPUT" 2>&1
EXIT_CODE=$?

# 显示完整输出（仅剥离 ANSI 颜色码）
ESC_CHAR=$(printf '\x1b'); sed "s/${ESC_CHAR}\[[0-9;]*m//g" "$GUT_OUTPUT"
rm -f "$GUT_OUTPUT"

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "=== [pre-commit] ❌ 测试失败（exit code: $EXIT_CODE），提交已阻止 ==="
    echo "请先修复测试再重新提交。"
    exit 1
fi

if [ -f "$TEST_OUTPUT" ]; then
    # grep -oP 支持 GNU grep；macOS 需 brew install grep 后用 ggrep
    FAILURES=$(grep -oP 'failures="\K[0-9]+' "$TEST_OUTPUT" 2>/dev/null)
    if [ "$FAILURES" != "0" ] && [ -n "$FAILURES" ]; then
        echo ""
        echo "=== [pre-commit] ❌ 发现 $FAILURES 个测试失败，提交已阻止 ==="
        exit 1
    fi
fi

echo "=== [pre-commit] ✅ 测试全部通过 ==="
